{
  "name": "@wsmk/wi-resource-loader",
  "version": "1.12.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "files": [
    "dist",
    "types",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vladislavkovaliov/resource-loader"
  },
  "scripts": {
    "build:old": "rm -rf dist && rm -rf types && tsc",
    "build": "rm -rf dist && tsup",
    "lint:fix": "npx @biomejs/biome format --write src",
    "test": "node --import tsx --test src/core/loader/loader.test.ts",
    "prepare": "husky || true"
  },
  "keywords": [
    "script",
    "css",
    "stylesheet",
    "loader",
    "dynamic-loading",
    "browser",
    "typescript",
    "lazy-load",
    "resource",
    "utility"
  ],
  "author": "",
  "license": "ISC",
  "description": "Lightweight TypeScript library for dynamically loading and unloading scripts and stylesheets in the browser",
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint",
      "npm run prettier"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./cz-adapter"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.6.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "inquirer": "^13.4.1",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
